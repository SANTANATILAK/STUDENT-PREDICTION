{
  "name": "Student Performance Prediction Hub",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "features": {},
  "postCreateCommand": "pip install -r requirements.txt && python -c \"from app import app, db; app.app_context().push(); db.create_all()\"",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "njpwerner.autodocstring"
      ]
    }
  },
  "forwardPorts": [5000, 8501],
  "portsAttributes": {
    "5000": {
      "label": "Flask Web Application",
      "onAutoForward": "openPreview"
    },
    "8501": {
      "label": "Streamlit Dashboard App",
      "onAutoForward": "silent"
    }
  }
}
